<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Label?>
<!-- TableView/TableColumn removed: replaced by a simple welcome/summary text -->

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/8"
            fx:controller="org.openjfx.sio2E4.controller.HomeViewController">

    <children>
        <VBox spacing="16.0" AnchorPane.topAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.bottomAnchor="10.0">
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Label fx:id="welcomeLabel" text="Bienvenue dans l'application!" style="-fx-font-size: 18px; -fx-padding: 8 0; -fx-font-weight: bold;" />
                <Label fx:id="subtitleLabel" text="Tableau de bord" style="-fx-text-fill: #666666; -fx-font-size: 12px;" />
            </HBox>

            <!-- Summary cards -->
            <HBox fx:id="cardsBox" spacing="14.0">
                <VBox fx:id="studentsCard" styleClass="card" spacing="6.0" prefWidth="220.0" prefHeight="80.0">
                    <Label text="Étudiants" style="-fx-font-weight: bold;" />
                    <Label fx:id="studentsCountLabel" text="0" style="-fx-font-size: 22px;" />
                </VBox>

                <VBox fx:id="teachersCard" styleClass="card" spacing="6.0" prefWidth="220.0" prefHeight="80.0">
                    <Label text="Enseignants" style="-fx-font-weight: bold;" />
                    <Label fx:id="teachersCountLabel" text="0" style="-fx-font-size: 22px;" />
                </VBox>

                <VBox fx:id="evaluationsCard" styleClass="card" spacing="6.0" prefWidth="220.0" prefHeight="80.0">
                    <Label text="Évaluations" style="-fx-font-weight: bold;" />
                    <Label fx:id="evaluationsCountLabel" text="0" style="-fx-font-size: 22px;" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />
            </HBox>

            <!-- Content: friendly welcome & app summary -->
            <VBox spacing="6.0">
                <Label text="À propos de Gnotes" style="-fx-font-weight: bold; -fx-padding: 6 0;" />

                <Label fx:id="homeMessageLabel" wrapText="true" text="Gnotes est une application de gestion des notes et des évaluations.\nVous pouvez créer et suivre les évaluations, gérer les matières, consulter les relevés des élèves, et ajouter des appréciations par matière dans le profil d'un étudiant. La vue d'accueil affiche un résumé rapide pour vous aider à naviguer." styleClass="home-summary" />

            </VBox>

        </VBox>
    </children>

</AnchorPane>
