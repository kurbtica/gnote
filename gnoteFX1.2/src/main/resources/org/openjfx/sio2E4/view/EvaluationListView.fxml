<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.text.Font?>
<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.openjfx.sio2E4.controller.EvaluationListController" spacing="20" alignment="TOP_CENTER" style="-fx-padding: 20;">

    <!-- En-tête avec titre et bouton d'ajout -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;" text="Évaluations">
                <font>
                    <Font name="System Bold" size="28" />
                </font>
            </Label>
            <Label style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" text="Gérez les évaluations de chaque étudiant de l'établissement." />
        </VBox>

        <Button fx:id="addNoteButton" onAction="#showCreateEvaluationPage" style="-fx-background-color: #82263c; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 6; -fx-cursor: hand;" text="+ Ajouter une évaluation">
            <font>
                <Font name="System Bold" size="14" />
            </font>
        </Button>
    </HBox>

    <!-- TableView pour afficher les notes -->
    <TableView fx:id="evaluationTable" prefWidth="951">
        <columns>
            <TableColumn fx:id="titleColumn" text="Titre" prefWidth="150" />
            <TableColumn fx:id="enseignantColumn" text="Enseignant" prefWidth="150" />
            <TableColumn fx:id="matiereColumn" text="Matière" prefWidth="120" />
            <TableColumn fx:id="moyennes" text="Moyennes" prefWidth="300">
                <columns>
                    <TableColumn fx:id="moyenneColumn" text="Classe" prefWidth="100"/>
                    <TableColumn fx:id="moyenneMinColumn" text="Min" prefWidth="100"/>
                    <TableColumn fx:id="moyenneMaxColumn" text="Max" prefWidth="100"/>
                </columns>
            </TableColumn>
            <TableColumn fx:id="coefficientColumn" text="Coef" prefWidth="70" />
            <TableColumn fx:id="noteTypeColumn" text="Type note" prefWidth="170" />
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="100" />

            <TableColumn fx:id="modificationColumn" text="Modification" prefWidth="150" />
            <TableColumn fx:id="actionsColumn" prefWidth="120" sortable="false" text="Actions" />
        </columns>
    </TableView>
    <!--<HBox spacing="10">
        <Button text="Supprimer" onAction="#handleDeleteNote" />
        <Button text="Modifier" onAction="#handleUpdateNote" />
    </HBox>-->
    <!-- Formulaire d'ajout d'une note
