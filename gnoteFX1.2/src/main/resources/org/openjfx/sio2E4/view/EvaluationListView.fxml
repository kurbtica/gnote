    <!-- TableView pour afficher les majors par semestre -->
    <Label text="Majors de promotion par semestre"
        style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: top-left;" />
    <TableView fx:id="majorsTable" prefHeight="200">
        <columns>
            <TableColumn fx:id="semestreColumn" text="Semestre" prefWidth="150" />
            <TableColumn fx:id="majorsColumn" text="Majors" prefWidth="400" />
        </columns>
    </TableView>


</VBox>