<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.Region?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx"
            fx:controller="org.openjfx.sio2E4.controller.MainLayoutController"
            stylesheets="@../css/AppLayout.css">

    <!-- Top Bar -->
    <top>
        <HBox spacing="20" styleClass="sidebar">
            <Label fx:id="usernameLabel" text="Bienvenue, ..."
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>

            <Region fx:id="spacer" HBox.hgrow="ALWAYS"/>

            <HBox fx:id="statusBadge" styleClass="status-button-neutral" alignment="CENTER_LEFT" spacing="5">
                <children>
                    <javafx.scene.shape.Circle fx:id="statusIndicator" radius="5" styleClass="circle-online"/>
                    <Label fx:id="statusLabel" text="En ligne"
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px;"/>
                </children>
            </HBox>

            <Button fx:id="logoutButton"
                    text="Déconnexion"
                    onMouseEntered="#onLogoutHover"
                    onMouseExited="#onLogoutHoverExit"
                    onAction="#handleLogout"
                    style="-fx-background-color: #f4f4f4; -fx-text-fill: #82263c;">
            </Button>
        </HBox>
    </top>


    <!-- Sidebar Navigation -->
    <left>
        <VBox fx:id="leftSidebar" spacing="10" styleClass="left" prefWidth="200">
            <Button text="Accueil" onAction="#showDashboard" maxWidth="Infinity"/>
            <Button text="Étudiants" onAction="#showEtudiants" maxWidth="Infinity"/>
            <Button text="Évaluations" onAction="#showEvaluationList" maxWidth="Infinity"/>
        </VBox>
    </left>


    <!-- Contenu principal -->
    <center>
        <StackPane fx:id="contentArea"/>
    </center>

</BorderPane>